# Copy to .env and .env.local, then fill in real values. Never commit .env or .env.local.

MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=amantillo_db
MYSQL_USER=amantillo_user
MYSQL_PASSWORD=change_me

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_string
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8080
# Railway/proxy deployments: trust the immediate proxy so Symfony sees HTTPS.
SYMFONY_TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://amantillo_user:change_me@127.0.0.1:3307/amantillo_db?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# Brevo (production): put xsmtpsib-... key in .env.local as BREVO_SMTP_KEY, then:
# MAILER_DSN=smtp://your-brevo-login@gmail.com:${BREVO_SMTP_KEY}@smtp-relay.brevo.com:587
# MAILER_FROM_ADDRESS must be a verified sender in Brevo.
# Local Docker (no Brevo key): Mailpit at http://localhost:8025
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM_ADDRESS=abenisamantillo04@gmail.com
MAILER_FROM_NAME="The Amantillo Property Co."
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
###< lexik/jwt-authentication-bundle ###

###> knpu/oauth2-client-bundle ###
# Create at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client, Web application).
# Authorized redirect URI must match your app URL + /connect/google/check
#   e.g. http://localhost:8080/connect/google/check  or  https://your-app.onrender.com/connect/google/check
# Put real values in .env.local only (never commit secrets).
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
###< knpu/oauth2-client-bundle ###

###> kreait/firebase-bundle ###
# Local Docker: put the Firebase Admin SDK JSON outside git at this path.
# Railway: leave FIREBASE_CREDENTIALS unset and set FIREBASE_CREDENTIALS_JSON instead.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS=/var/www/html/config/firebase/service-account.json
###< kreait/firebase-bundle ###
