{% extends 'layouts/admin_layout.html.twig' %}

{% block title %}{{ company_name }} - Dashboard{% endblock %}

{% block content %}
        <section class="dashboard-welcome" aria-label="Dashboard welcome">
            <div class="dashboard-welcome-inner">
                <p class="dashboard-welcome-kicker">Portfolio overview</p>
                <h1>{{ company_name }}</h1>
                <p>{{ tagline }} — Track listings, sales, and revenue across your property portfolio.</p>
            </div>
        </section>

        <div class="dashboard-tabs">
            <button class="tab-button active" data-tab="overview">Portfolio snapshot</button>
        </div>

        <div id="overview-tab" class="tab-content active">
            <div class="metrics-section">
                <h2 class="metrics-section-title">Property listings</h2>
                <div class="metrics-row">
                    <div class="metric-card-modern metric-card-modern--properties">
                        <div class="metric-header">
                            <div>
                                <div class="metric-label-modern">Active listings</div>
                                <div class="metric-value-modern" id="metric-total-properties">{{ metrics.total_properties }}</div>
                            </div>
                            <div class="metric-icon-modern" aria-hidden="true">▣</div>
                        </div>
                    </div>

                    <div class="metric-card-modern metric-card-modern--pending">
                        <div class="metric-header">
                            <div>
                                <div class="metric-label-modern">Pending approval</div>
                                <div class="metric-value-modern" id="metric-properties-pending">{{ metrics.properties_pending }}</div>
                            </div>
                            <div class="metric-icon-modern" aria-hidden="true">◷</div>
                        </div>
                    </div>

                    <div class="metric-card-modern metric-card-modern--sold">
                        <div class="metric-header">
                            <div>
                                <div class="metric-label-modern">Properties sold</div>
                                <div class="metric-value-modern" id="metric-properties-sold">{{ metrics.properties_sold }}</div>
                            </div>
                            <div class="metric-icon-modern" aria-hidden="true">✓</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="metrics-section">
                <h2 class="metrics-section-title">Furnishings &amp; revenue</h2>
                <div class="metrics-row">
                    <div class="metric-card-modern metric-card-modern--furniture">
                        <div class="metric-header">
                            <div>
                                <div class="metric-label-modern">Furniture in catalog</div>
                                <div class="metric-value-modern" id="metric-total-furnitures">{{ metrics.total_furnitures }}</div>
                            </div>
                            <div class="metric-icon-modern" aria-hidden="true">◫</div>
                        </div>
                    </div>

                    <div class="metric-card-modern metric-card-modern--furniture">
                        <div class="metric-header">
                            <div>
                                <div class="metric-label-modern">Furniture sold</div>
                                <div class="metric-value-modern" id="metric-furnitures-sold">{{ metrics.furnitures_sold }}</div>
                            </div>
                            <div class="metric-icon-modern" aria-hidden="true">◫</div>
                        </div>
                    </div>

                    <div class="metric-card-modern metric-card-modern--revenue">
                        <div class="metric-header">
                            <div>
                                <div class="metric-label-modern">Total revenue</div>
                                <div class="metric-value-modern" id="metric-total-revenue">{{ metrics.total_revenue }}</div>
                            </div>
                            <div class="metric-icon-modern" aria-hidden="true">₱</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const tabButtons = document.querySelectorAll('.tab-button');
                const tabContents = document.querySelectorAll('.tab-content');

                tabButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const targetTab = this.getAttribute('data-tab');
                        tabButtons.forEach(btn => btn.classList.remove('active'));
                        tabContents.forEach(content => content.classList.remove('active'));
                        this.classList.add('active');
                        document.getElementById(targetTab + '-tab').classList.add('active');
                    });
                });

                const liveEndpoint = '{{ path('app_dashboard_live_metrics') }}';
                let isFetching = false;

                const applyMetrics = function (metrics) {
                    const mapping = {
                        total_properties: 'metric-total-properties',
                        properties_pending: 'metric-properties-pending',
                        properties_sold: 'metric-properties-sold',
                        total_furnitures: 'metric-total-furnitures',
                        furnitures_sold: 'metric-furnitures-sold',
                        total_revenue: 'metric-total-revenue',
                    };

                    Object.keys(mapping).forEach(function (key) {
                        const element = document.getElementById(mapping[key]);
                        if (element && Object.prototype.hasOwnProperty.call(metrics, key)) {
                            element.textContent = String(metrics[key]);
                        }
                    });
                };

                const fetchLiveMetrics = async function () {
                    if (isFetching || document.hidden) {
                        return;
                    }

                    isFetching = true;
                    try {
                        const response = await fetch(liveEndpoint, {
                            method: 'GET',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        });

                        if (!response.ok) {
                            return;
                        }

                        const payload = await response.json();
                        if (payload && typeof payload === 'object' && payload.metrics) {
                            applyMetrics(payload.metrics);
                        }
                    } catch (error) {
                        // Ignore transient polling errors.
                    } finally {
                        isFetching = false;
                    }
                };

                setInterval(fetchLiveMetrics, 3000);
            });
        </script>
{% endblock %}
