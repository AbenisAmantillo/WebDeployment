{% extends 'layouts/admin_layout.html.twig' %}

{% block title %}View All Data Records{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const container = document.getElementById('dataRecordsContentContainer');
            const liveEndpoint = '{{ path('app_data_records_live_content') }}';
            let isFetching = false;

            const fetchLatestContent = async function () {
                if (isFetching || !container) {
                    return;
                }

                isFetching = true;
                try {
                    const response = await fetch(liveEndpoint, {
                        method: 'GET',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    });
                    if (!response.ok) {
                        return;
                    }

                    const payload = await response.json();
                    if (typeof payload.html !== 'string') {
                        return;
                    }

                    const nextHtml = payload.html.trim();
                    if (container.innerHTML.trim() !== nextHtml) {
                        container.innerHTML = nextHtml;
                    }
                } catch (error) {
                    // Silently ignore transient polling failures.
                } finally {
                    isFetching = false;
                }
            };

            setInterval(fetchLatestContent, 5000);
        });
    </script>
{% endblock %}

{% block content %}
<div class="data-records-container">
    <div class="data-records-header">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: middle; margin-right: 0.5rem;">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            View All Data Records
        </h1>
        <p>Comprehensive view of all properties, furniture, transactions, and payments in the system</p>
    </div>

    <div id="dataRecordsContentContainer">
        {% include 'data_records/_content.html.twig' with {
            properties: properties,
            furniture: furniture,
            transactions: transactions,
            payments: payments,
            total_properties: total_properties,
            total_furniture: total_furniture,
            total_transactions: total_transactions,
            total_payments: total_payments
        } %}
    </div>
</div>
{% endblock %}

