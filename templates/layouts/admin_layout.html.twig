{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/crud.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/clients.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/activity_logs.css') }}">
{% endblock %}

{% block body %}
<div class="dashboard-wrapper">
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <div class="logo-image"></div>
                <div>
                    <span class="logo-text">The Amantillo Property Co.</span>
                    <span class="sidebar-tagline">Property Management</span>
                </div>
            </div>
            <button class="sidebar-toggle">☰</button>
        </div>
        
        <nav class="sidebar-nav">
            <span class="sidebar-nav-label">Portfolio</span>
            <a href="{{ path('app_dashboard') }}" class="sidebar-link {% if app.request.attributes.get('_route') == 'app_dashboard' %}active{% endif %}">
                <span class="sidebar-icon">⌂</span>
                <span class="sidebar-text">Overview</span>
            </a>
            <a href="{{ path('app_property_index') }}" class="sidebar-link {% if 'app_property' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="sidebar-icon">▣</span>
                <span class="sidebar-text">Property Management</span>
            </a>
            <a href="{{ path('app_furniture_index') }}" class="sidebar-link {% if 'app_furniture' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="sidebar-icon">◫</span>
                <span class="sidebar-text">Furniture Management</span>
            </a>

            <span class="sidebar-nav-label">Operations</span>
            <a href="{{ path('app_transaction_index') }}" class="sidebar-link {% if 'app_transaction' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="sidebar-icon">⇄</span>
                <span class="sidebar-text">Transactions</span>
            </a>
            <a href="{{ path('app_payment_index') }}" class="sidebar-link {% if 'app_payment' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="sidebar-icon">₱</span>
                <span class="sidebar-text">Payments</span>
            </a>

            {% if is_granted('ROLE_ADMIN') %}
            <span class="sidebar-nav-label">Administration</span>
            <a href="{{ path('app_clients_index') }}" class="sidebar-link {% if 'app_clients' in app.request.attributes.get('_route') or 'app_client' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="sidebar-icon">◎</span>
                <span class="sidebar-text">User Management</span>
            </a>
            <a href="{{ path('app_activity_log_index') }}" class="sidebar-link {% if 'app_activity_log' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="sidebar-icon">☰</span>
                <span class="sidebar-text">Activity Logs</span>
            </a>
            <a href="{{ path('app_notification_index') }}" class="sidebar-link {% if 'app_notification' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="sidebar-icon">◉</span>
                <span class="sidebar-text">Notifications</span>
            </a>
            {% endif %}
        </nav>
    </aside>

    <!-- Main Content Area -->
    <main class="main-dashboard">
        <!-- Top Header with User Profile -->
        <div class="top-header-bar">
            <div class="user-profile-container">
                <div class="user-profile-dropdown" id="userProfileDropdown">
                    <div class="user-profile-trigger">
                        {% if app.user %}
                            <span class="user-profile-avatar">{% include 'partials/user_avatar.html.twig' with { user: app.user, size: 'sm' } %}</span>
                        {% else %}
                            <span class="user-icon">👤</span>
                        {% endif %}
                        <span class="user-greeting">Hi {{ app.user ? app.user.userIdentifier : 'Guest' }}</span>
                        <span class="dropdown-arrow">▼</span>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div style="padding: 1rem; border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
                            <div style="display:flex;align-items:center;gap:0.75rem;">
                                {% if app.user %}
                                    {% include 'partials/user_avatar.html.twig' with { user: app.user, size: 'sm' } %}
                                {% endif %}
                                <div>
                                    <div style="font-weight: 600; color: #1f2937; font-size: 0.95rem;">{{ app.user ? app.user.username : 'Guest' }}</div>
                                    <div style="font-size: 0.875rem; color: #6b7280; margin-top: 0.25rem;">{% if app.user and 'ROLE_ADMIN' in app.user.roles %}Admin Account{% elseif app.user and 'ROLE_STAFF' in app.user.roles %}Staff Account{% else %}User Account{% endif %}</div>
                                </div>
                            </div>
                        </div>
                        {% if app.user and ('ROLE_ADMIN' in app.user.roles or 'ROLE_STAFF' in app.user.roles) %}
                            <a href="{{ path('app_account_profile') }}" class="dropdown-item">
                                <span>⚙</span>
                                <span>My account</span>
                            </a>
                        {% endif %}
                            <a href="{{ path('app_logout') }}" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; color: #dc2626; text-decoration: none; border-radius: 8px; transition: all 0.2s; font-weight: 500; font-size: 0.95rem;">
                                <span>🚪</span>
                                <span>Log Out</span>
                            </a>
                    </div>
                </div>
            </div>
        </div>
        {% block content %}{% endblock %}
    </main>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Sidebar toggle for mobile
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarToggle = document.querySelector('.sidebar-toggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function() {
                    document.querySelector('.sidebar').classList.toggle('mobile-open');
                });
            }

            // User profile dropdown toggle
            const userProfileTrigger = document.querySelector('.user-profile-trigger');
            const userProfileMenu = document.getElementById('userProfileMenu');
            const userProfileDropdown = document.getElementById('userProfileDropdown');
            
            if (userProfileTrigger && userProfileMenu && userProfileDropdown) {
                userProfileTrigger.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    userProfileMenu.classList.toggle('show');
                    userProfileDropdown.classList.toggle('active');
                });

                // Close dropdown when clicking outside
                document.addEventListener('click', function(e) {
                    if (!userProfileDropdown.contains(e.target)) {
                        userProfileMenu.classList.remove('show');
                        userProfileDropdown.classList.remove('active');
                    }
                });
            }

            // Auto-refresh admin pages so latest records and dashboard totals stay up to date.
            const currentRoute = '{{ app.request.attributes.get('_route')|default('') }}';
            const excludedRoutes = [
                'app_notification_new',
                'app_transaction_new',
                'app_transaction_process_payment',
                'app_property_new',
                'app_property_edit',
                'app_furniture_new',
                'app_furniture_edit',
                'app_account_profile'
            ];

            if (!excludedRoutes.includes(currentRoute)) {
                let hasUnsavedChanges = false;
                let lastKnownVersion = null;
                const formInputs = document.querySelectorAll('form input, form select, form textarea');
                const liveVersionEndpoint = '{{ path('app_admin_live_version') }}';

                formInputs.forEach(function (input) {
                    input.addEventListener('change', function () {
                        hasUnsavedChanges = true;
                    });
                    input.addEventListener('input', function () {
                        hasUnsavedChanges = true;
                    });
                });

                setInterval(async function () {
                    if (document.hidden || hasUnsavedChanges) {
                        return;
                    }

                    try {
                        const response = await fetch(liveVersionEndpoint, {
                            method: 'GET',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        });

                        if (!response.ok) {
                            return;
                        }

                        const payload = await response.json();
                        if (typeof payload.version !== 'string') {
                            return;
                        }

                        if (lastKnownVersion === null) {
                            lastKnownVersion = payload.version;
                            return;
                        }

                        if (lastKnownVersion !== payload.version) {
                            window.location.reload();
                        }
                    } catch (error) {
                        // Ignore temporary connectivity issues.
                    }
                }, 3000);
            }
        });
    </script>
{% endblock %}

