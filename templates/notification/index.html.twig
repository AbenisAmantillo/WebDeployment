{% extends 'layouts/admin_layout.html.twig' %}

{% block title %}Client Notifications{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const container = document.getElementById('notificationListContainer');
            const liveEndpoint = '{{ path('app_notification_live_list') }}';
            let isFetching = false;

            const fetchLatestList = async function () {
                if (isFetching || !container) {
                    return;
                }

                isFetching = true;
                try {
                    const response = await fetch(liveEndpoint, {
                        method: 'GET',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    });
                    if (!response.ok) {
                        return;
                    }

                    const payload = await response.json();
                    if (typeof payload.html !== 'string') {
                        return;
                    }

                    const nextHtml = payload.html.trim();
                    if (container.innerHTML.trim() !== nextHtml) {
                        container.innerHTML = nextHtml;
                    }
                } catch (error) {
                    // Silently ignore transient polling failures.
                } finally {
                    isFetching = false;
                }
            };

            setInterval(fetchLatestList, 5000);
        });
    </script>
{% endblock %}

{% block content %}
<div class="admin-page clients-container">
    {% include 'partials/admin_page_header.html.twig' with {
        kicker: 'Administration',
        title: 'Client notifications',
        description: 'Messages delivered to clients via the mobile app',
        actions_html: '<a href="' ~ path('app_notification_new') ~ '" class="btn btn-primary" style="color:#0f1c2e;background:#c9a227;border-color:#c9a227;">Send notification</a>'
    } only %}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="admin-flash admin-flash--{{ label == 'error' ? 'error' : (label == 'success' ? 'success' : 'info') }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <p class="admin-table-hint">Scroll horizontally if columns are cut off →</p>
    <div class="table-wrapper">
        <div id="notificationListContainer">
            {% include 'notification/_list_content.html.twig' with { notifications: notifications } %}
        </div>
    </div>
</div>
{% endblock %}
