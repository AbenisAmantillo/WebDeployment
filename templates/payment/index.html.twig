{% extends 'layouts/admin_layout.html.twig' %}

{% block title %}Payment Management{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tableBody = document.getElementById('paymentTableBody');
            const liveEndpoint = '{{ path('app_payment_live_rows') }}';
            let isFetching = false;

            const fetchLatestRows = async function () {
                if (isFetching || !tableBody) {
                    return;
                }

                isFetching = true;
                try {
                    const response = await fetch(liveEndpoint, {
                        method: 'GET',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    });
                    if (!response.ok) {
                        return;
                    }

                    const payload = await response.json();
                    if (typeof payload.html !== 'string') {
                        return;
                    }

                    const nextHtml = payload.html.trim();
                    if (tableBody.innerHTML.trim() !== nextHtml) {
                        tableBody.innerHTML = nextHtml;
                    }
                } catch (error) {
                    // Silently ignore transient polling failures.
                } finally {
                    isFetching = false;
                }
            };

            setInterval(fetchLatestRows, 5000);
        });
    </script>
{% endblock %}

{% block content %}
<div class="admin-page property-container">
    {% include 'partials/admin_page_header.html.twig' with {
        kicker: 'Operations',
        title: 'Payments',
        description: 'Submitted installment confirmations and completed payment records'
    } only %}

    <p class="admin-table-hint">Scroll horizontally if columns are cut off →</p>
    <div class="table-wrapper">
        <table class="property-table property-table--wide">
            <thead>
                <tr>
                    <th class="col-id">Payment ID</th>
                    <th class="col-title">Customer</th>
                    <th class="col-id">Transaction</th>
                    <th class="col-price">Amount</th>
                    <th class="col-title">Method</th>
                    <th class="col-id">Status</th>
                    <th class="col-price">Date</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody id="paymentTableBody">
                {% include 'payment/_table_rows.html.twig' with { payments: payments } %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
