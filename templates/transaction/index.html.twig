{% extends 'layouts/admin_layout.html.twig' %}

{% block title %}Transaction Report{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            const tableBody = document.getElementById('transactionTableBody');
            const liveEndpoint = '{{ path('app_transaction_live_rows') }}';
            let isFetching = false;

            const applySearchFilter = function () {
                if (!searchInput || !tableBody) {
                    return;
                }

                const query = searchInput.value.trim().toLowerCase();
                const rows = tableBody.querySelectorAll('tr');
                rows.forEach(function (row) {
                    if (row.querySelector('.admin-table-empty')) {
                        row.style.display = '';
                        return;
                    }
                    row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
                });
            };

            const fetchLatestRows = async function () {
                if (isFetching || !tableBody) {
                    return;
                }

                isFetching = true;
                try {
                    const response = await fetch(liveEndpoint, {
                        method: 'GET',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    });
                    if (!response.ok) {
                        return;
                    }

                    const payload = await response.json();
                    if (typeof payload.html !== 'string') {
                        return;
                    }

                    const nextHtml = payload.html.trim();
                    if (tableBody.innerHTML.trim() !== nextHtml) {
                        tableBody.innerHTML = nextHtml;
                        applySearchFilter();
                    }
                } catch (error) {
                    // Silently ignore transient polling failures.
                } finally {
                    isFetching = false;
                }
            };

            if (searchInput) {
                searchInput.addEventListener('input', applySearchFilter);
            }

            setInterval(fetchLatestRows, 5000);
        });
    </script>
{% endblock %}

{% block content %}
<div class="admin-page transaction-container">
    <div class="transaction-header-section">
        <div class="header-left">
            <p class="admin-page-kicker">Operations</p>
            <h1>Transactions</h1>
            <p>Property purchases, payment status, and installment tracking</p>
        </div>
        <div class="header-right">
            {% if not is_granted('ROLE_ADMIN') and user_can_create_transaction|default(true) %}
            <a href="{{ path('app_transaction_new') }}" class="btn btn-primary" style="color:#0f1c2e;background:#c9a227;border-color:#c9a227;">+ New transaction</a>
            {% elseif not is_granted('ROLE_ADMIN') and not user_can_create_transaction|default(true) %}
            <span class="btn btn-secondary" style="cursor: not-allowed; opacity: 0.7;" title="Fully pay your current transaction before creating a new one">Payment incomplete</span>
            {% endif %}
        </div>
    </div>

    <div class="admin-toolbar toolbar">
        <div class="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input type="text" id="searchInput" placeholder="Search transactions...">
        </div>
        <div class="toolbar-actions">
            <button type="button" class="btn btn-secondary" onclick="window.print()">Export</button>
        </div>
    </div>

    <p class="admin-table-hint">Scroll horizontally to see all columns →</p>
    <div class="transaction-section">
        <div class="transaction-table-wrapper">
            <table class="transaction-table">
                <thead>
                    <tr>
                        <th>Transaction ID</th>
                        <th>Customer</th>
                        <th>Property</th>
                        <th>Purchase type</th>
                        <th>Furniture</th>
                        <th>Total</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="transactionTableBody">
                    {% include 'transaction/_table_rows.html.twig' with { transactions: transactions } %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
